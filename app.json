{
  "expo": {
    "name": "SeekerLens",
    "slug": "seekerlens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "seekerlens",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFA"
    },
    "android": {
      "package": "com.seekerlens.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAFAFA",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "SeekerLens needs camera access to capture photos for bounties and marketplace."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SeekerLens needs your location to verify photo authenticity and find nearby bounties."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "com.seekerlens.app"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b923ac89-3acc-4a6e-b6b9-0f4120e85d2c"
      }
    },
    "owner": "cryptoeights"
  }
}
